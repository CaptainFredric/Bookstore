{
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 100,
    "liveServer.settings.port": 5502,
    "liveServer.settings.NoBrowserCache": true,
    "liveServer.settings.fullReload": true,
    "liveServer.settings.ignoreFiles": [
        "**/.git/**",
        "**/.svn/**",
        "**/.hg/**",
        "**/CVS/**",
        "**/.DS_Store",
        "**/.venv/**",
        "**/node_modules/**"
    ]
}